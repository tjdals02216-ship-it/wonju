<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <title>지원 이력 관리</title>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@400;700&display=swap');
    body { font-family: 'Noto Sans KR', sans-serif; background-color: #f4f7f6; color: #333; margin: 0; padding: 40px; display: flex; justify-content: center; }
    .container { background: white; padding: 30px 40px; border-radius: 12px; box-shadow: 0 4px 15px rgba(0,0,0,0.05); width: 100%; max-width: 600px; }
    h1 { font-size: 24px; margin-bottom: 20px; color: #2c3e50; letter-spacing: -0.5px; }
    .btn-add { display: inline-block; background-color: #007bff; color: white; text-decoration: none; padding: 10px 16px; border-radius: 8px; font-weight: bold; font-size: 14px; margin-bottom: 24px; transition: all 0.2s; box-shadow: 0 2px 4px rgba(0,123,255,0.2); }
    .btn-add:hover { background-color: #0056b3; transform: translateY(-2px); }
    ul { list-style: none; padding: 0; margin: 0; }
    li { background: #fdfdfd; border: 1px solid #eee; padding: 20px; border-radius: 10px; margin-bottom: 12px; display: flex; justify-content: space-between; align-items: center; transition: 0.2s; }
    li:hover { box-shadow: 0 4px 10px rgba(0,0,0,0.08); border-color: #ddd; }
    .info { display: flex; flex-direction: column; }
    .company { font-size: 18px; font-weight: 700; color: #2c3e50; margin-bottom: 4px; }
    .role { font-size: 14px; color: #7f8c8d; }
    .status { font-size: 13px; font-weight: bold; padding: 6px 12px; border-radius: 20px; background-color: #e8f4fd; color: #007bff; }
  </style>
</head>
<body>
  <div class="container">
    <h1>💼 나의 실무/대외활동 지원 현황</h1>
    <a href="/write" class="btn-add">+ 새로운 지원 이력 추가하기</a>
    <ul>
      <% apps.forEach(app => { %>
        <li>
          <div class="info">
            <span class="company"><%= app.company %></span>
            <span class="role"><%= app.role %></span>
          </div>
          <span class="status"><%= app.status %></span>
        </li>
      <% }) %>
    </ul>
  </div>
</body>
</html>